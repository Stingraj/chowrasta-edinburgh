# Titan SMTP Configuration
# The contact form reads these server-side variables in production.
TITAN_EMAIL=your_titan_mailbox@example.com
TITAN_PASSWORD=your_titan_mailbox_password_here
TO_EMAIL=your_destination_inbox@example.com

# Sanity CMS Configuration
# Your Sanity Project ID (find this in sanity.config.ts or at https://manage.sanity.io)
SANITY_PROJECT_ID=your_sanity_project_id_here

# Your Sanity Dataset (typically "production")
SANITY_DATASET=production
