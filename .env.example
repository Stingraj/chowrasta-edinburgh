# GoDaddy Titan SMTP Configuration (Email settings for Nodemailer)
# The SMTP server host (GoDaddy Titan SMTP host)
SMTP_HOST=smtp.titan.email

# SMTP port. 465 is standard for SSL, 587 is standard for TLS/STARTTLS
SMTP_PORT=465

# Set to true if port is 465 (SSL), false if 587
SMTP_SECURE=true

# Your Titan email account username
SMTP_USER=service@chowrastaedi.com

# Your Titan email account password
SMTP_PASS=your_email_password_here

# The recipient email where form submissions will be sent
SMTP_TO=service@chowrastaedi.com

# Sanity CMS Configuration
# Your Sanity Project ID (find this in sanity.config.ts or at https://manage.sanity.io)
SANITY_PROJECT_ID=your_sanity_project_id_here

# Your Sanity Dataset (typically "production")
SANITY_DATASET=production
